{
  "name": "archik",
  "version": "0.6.8",
  "description": "Architecture diagrams as YAML. Live canvas in the browser, headless SVG render in CI, and an installable Claude skill so the model edits the same file you do.",
  "keywords": [
    "architecture",
    "diagram",
    "yaml",
    "elk",
    "svg",
    "cli",
    "documentation",
    "claude",
    "llm"
  ],
  "license": "MIT",
  "author": "Bashar <welcomebachar@gmail.com>",
  "type": "module",
  "bin": {
    "archik": "bin/archik.js"
  },
  "files": [
    "bin",
    "dist",
    "docs/hero.svg",
    ".claude/skills/archik",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build.mjs",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "archik": "tsx --tsconfig tsconfig.app.json src/cli/index.ts",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "chokidar": "^4.0.3",
    "elkjs": "^0.10.2",
    "esbuild": "^0.28.0",
    "jsdom": "^25.0.1",
    "lucide-react": "^0.470.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^3.2.4",
    "yaml": "^2.8.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  }
}
