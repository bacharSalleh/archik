{
  "name": "archik",
  "version": "0.1.0",
  "description": "JSON-native architecture diagram tool. The YAML file is the source of truth; the canvas is a stateless projection. Humans and LLMs edit the same file.",
  "keywords": [
    "architecture",
    "diagram",
    "yaml",
    "elk",
    "svg",
    "react",
    "vite",
    "cli",
    "documentation",
    "claude",
    "llm"
  ],
  "license": "MIT",
  "author": "Bashar <welcomebachar@gmail.com>",
  "type": "module",
  "bin": {
    "archik": "./bin/archik.js"
  },
  "files": [
    "bin",
    "src",
    "vite",
    "index.html",
    "tsconfig.json",
    "tsconfig.app.json",
    "tsconfig.node.json",
    "vite.config.ts",
    ".claude/skills/archik.md",
    "README.md",
    "LICENSE",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/__fixtures__",
    "!src/test-setup.ts",
    "!**/*.tsbuildinfo"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "archik": "tsx --tsconfig tsconfig.app.json src/cli/index.ts",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@vitejs/plugin-react": "^5.2.0",
    "chokidar": "^4.0.3",
    "elkjs": "^0.10.2",
    "lucide-react": "^0.470.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "vite": "^7.3.2",
    "yaml": "^2.8.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^25.0.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
